# Zone monorepo — cross-cutting ignores.
# Stack-specific rules live in backend/.gitignore and web/.gitignore.

# ── OS ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editors / IDEs ────────────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.swp
*.swo
*.suo

# ── Secrets / env files (never commit) ────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
secrets/

# ── Logs ──────────────────────────────────────────────────────────────
*.log
logs/

# ── Dependency / build caches (defensive — subdirs also cover these) ──
**/node_modules/
**/.pnpm-store/
**/build/
**/dist/
**/target/
**/.gradle/
**/.vite/

# ── Coverage / temp ───────────────────────────────────────────────────
coverage/
*.lcov
*.tmp
*.bak

# ── just runtime (PIDs, logs from `just up`) ──────────────────────────
.run/

# ── Claude Code per-user state ────────────────────────────────────────
# .claude/launch.json IS committed (shared dev-server config).
# Personal overrides and caches are not.
.claude/settings.local.json
.claude/cache/
